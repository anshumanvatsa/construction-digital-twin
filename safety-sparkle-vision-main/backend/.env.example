PROJECT_NAME=Construction Site Digital Twin Backend
ENVIRONMENT=dev
API_V1_PREFIX=

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=construction_twin

REDIS_URL=redis://redis:6379/0

SIMULATION_INTERVAL_SECONDS=1.0
SIMULATION_CHANNEL=simulation:updates

RISK_HIGH_THRESHOLD=75
RISK_MEDIUM_THRESHOLD=40

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_DEFAULT=120/minute

SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

AUTO_START_SIMULATION=true
DEFAULT_ADMIN_EMAIL=admin@site.local
DEFAULT_ADMIN_PASSWORD=admin12345

AUTO_CREATE_TABLES=true
AUTO_SEED_DATA=true
