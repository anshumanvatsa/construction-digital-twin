PROJECT_NAME=Construction Site Digital Twin Backend
ENVIRONMENT=prod
API_V1_PREFIX=

# 🔗 DATABASE (from Render PostgreSQL)
DB_HOST=<RENDER_DB_HOST>
DB_PORT=5432
DB_USER=<RENDER_DB_USER>
DB_PASSWORD=<RENDER_DB_PASSWORD>
DB_NAME=<RENDER_DB_NAME>

# 🔗 REDIS (from Render Redis)
REDIS_URL=<RENDER_REDIS_URL>

SIMULATION_INTERVAL_SECONDS=1.0
SIMULATION_CHANNEL=simulation:updates

RISK_HIGH_THRESHOLD=75
RISK_MEDIUM_THRESHOLD=40

# 🌐 FRONTEND URL (VERY IMPORTANT)
CORS_ORIGINS=https://your-frontend.vercel.app

RATE_LIMIT_DEFAULT=120/minute

# 🔐 SECURITY (CHANGE THIS!)
SECRET_KEY=super-secure-random-string-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

AUTO_START_SIMULATION=true
DEFAULT_ADMIN_EMAIL=admin@site.local
DEFAULT_ADMIN_PASSWORD=admin12345

AUTO_CREATE_TABLES=true
AUTO_SEED_DATA=true